# Environment variables — documented shape only (docs/10 §3; docs/09 §11).
#
# Tier 0 static launch needs NONE of these. Copy to .env.local for local
# dev; production/preview secrets live in the host's env store (Render).
# NEVER commit real values to git.

# ── Content source ──────────────────────────────────────────────────────────
# 'file' (default) reads content/site.ts — always works, no DB needed.
# 'db'   reads from PostgreSQL via Drizzle (requires DATABASE_URL below).
# CI always runs without CONTENT_SOURCE set → defaults to file mode.
# CONTENT_SOURCE=file

# ── Database (docs/09) ──────────────────────────────────────────────────────
# Required when CONTENT_SOURCE=db. Use docker-compose.dev.yml for local dev
# (see repo root). Production value lives in Render's environment group.
# DATABASE_URL=postgresql://deepak:devpassword@localhost:5432/deepak_labs_dev

# ── Admin CMS auth (docs/27 §4, D-047 Option A) ────────────────────────────
# SESSION_SECRET: min 32 random bytes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# SESSION_SECRET=

# ADMIN_PASSWORD_HASH: bcrypt hash of the owner passphrase. Generate with:
#   node -e "const b=require('bcryptjs'); b.hash('yourPassphrase',12).then(h=>console.log(h))"
# ADMIN_PASSWORD_HASH=

# ── Media storage — Cloudflare R2 (D-049, docs/28 §6) ──────────────────────
# Required only to upload images/PDFs from the admin. The public site reads
# media via MEDIA_PUBLIC_BASE_URL. All four R2_* values are SECRETS (env only,
# never committed). See README → "Media / R2 setup" for bucket + CORS steps.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=deepak-labs-media
# Public origin for reads (the bucket's r2.dev URL or a custom domain).
# NOT a secret — it is the public asset host. Empty → media features stay off.
# MEDIA_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev

# ── AI / Dex sprint (docs/11 §11, provider-agnostic) ───────────────────────
# LLM_API_KEY=
# EMBEDDING_API_KEY=

# ── GitHub sync (D-010) ─────────────────────────────────────────────────────
# GITHUB_TOKEN=
